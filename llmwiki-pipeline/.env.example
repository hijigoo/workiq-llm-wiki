# ================================================================
#  LLM Wiki Pipeline — environment configuration
#  Copy this file to `.env` and fill in the values.
#  `.env` is gitignored — never commit real credentials.
#
#  Full tenant / Entra ID setup: see SETUP.md
# ================================================================

# ---- Required: Entra ID (Azure AD) ----
# Directory (tenant) ID that owns the Mail / Teams MCP servers.
TENANT_ID=

# Application (client) ID of your Entra app registration.
# For the default device-code flow the app must have "Allow public client
# flows" = Yes and delegated, admin-consented permissions to the Agent Tools
# resource (McpServers.Mail.All / McpServers.Teams.All). See SETUP.md.
CLIENT_ID=

# Client secret — required ONLY when AUTH_MODE=client_credentials (app-only,
# advanced / usually unavailable). Leave empty for device-code (delegated).
CLIENT_SECRET=

# ---- MCP servers (optional) ----
# Leave BLANK to auto-derive from TENANT_ID (recommended):
#   https://agent365.svc.cloud.microsoft/agents/tenants/<TENANT_ID>/servers/mcp_MailTools
#   https://agent365.svc.cloud.microsoft/agents/tenants/<TENANT_ID>/servers/mcp_TeamsServer
# Only set these if your tenant uses non-standard URLs.
MAIL_MCP_SERVER_URL=
TEAMS_MCP_SERVER_URL=

# ---- Work IQ MCP (notebooks 05 / 06 only) ----
# Notebooks 05/06 connect to the newer **Work IQ MCP** server (a SINGLE endpoint
# exposing 10 generic, path-based tools: fetch / ask / search_paths / ...).
#
# AUTH: by DEFAULT they are UNIFIED with the web app / notebooks 01-04 — same
# self-registered app (CLIENT_ID above) + device-code (AUTH_MODE above) + the
# shared cache (TOKEN_CACHE_PATH above), so a single sign-in is reused. This
# requires your app registration to have the 'WorkIQAgent.Ask' delegated
# permission consented (same as the web app). Just set CLIENT_ID / TENANT_ID.
#
# OPTION: set WORKIQ_USE_PUBLIC_CLIENT=true to instead use Microsoft's public
# Work IQ client (no app registration needed). Only then do the WORKIQ_CLIENT_ID
# / WORKIQ_AUTH_MODE / WORKIQ_TOKEN_CACHE_PATH values below take effect.
# Either way: work/school account + admin consent + EULA (no personal accounts).
#
# MCP endpoint (blank => https://workiq.svc.cloud.microsoft/mcp):
WORKIQ_MCP_SERVER_URL=
# Delegated scope (blank => fdcc1f02-...-.../WorkIQAgent.Ask); applies to both modes:
WORKIQ_SCOPE=
#
# Use Microsoft's public Work IQ client instead of your own app (blank/false => unified default):
WORKIQ_USE_PUBLIC_CLIENT=false
# --- The rest only apply when WORKIQ_USE_PUBLIC_CLIENT=true ---
# Public client (blank => Microsoft's Work IQ client ba081686-...; no app registration needed):
WORKIQ_CLIENT_ID=
# Sign-in flow for the public-client option: interactive (default) | device_code:
WORKIQ_AUTH_MODE=interactive
# Loopback redirect port for interactive sign-in (Work IQ's registered reply URL):
WORKIQ_REDIRECT_PORT=12798
# Separate token cache for the public-client option (gitignored). Delete to force a fresh login:
WORKIQ_TOKEN_CACHE_PATH=.workiq.token_cache.json

# ---- Auth mode ----
# device_code       : delegated user login shown once in notebook 01 / terminal,
#                     then cached to TOKEN_CACHE_PATH and reused silently.
#                     RECOMMENDED — the MCP servers expose delegated scopes.
# client_credentials: app-only token via CLIENT_SECRET. Advanced and usually
#                     NOT available: it only works if Agent Tools exposes and
#                     your tenant grants matching *application* roles. A secret
#                     alone cannot substitute for delegated scopes.
AUTH_MODE=device_code

# Token cache path (delegated login cache). Treat this file as a credential
# (e.g. chmod 600). It is gitignored. Delete it to force a fresh login.
TOKEN_CACHE_PATH=.token_cache.json

# ---- LLM (natural-language extraction + markdown generation) ----
# Pick ONE provider. The LLM identity is SEPARATE from the Microsoft 365
# delegated user identity used for the MCP calls.
#
# Azure OpenAI (Foundry): when AZURE_OPENAI_API_KEY is empty, auth is by Entra
# ID via DefaultAzureCredential (`az login` / managed identity). That identity
# needs a data-plane role (e.g. "Cognitive Services OpenAI User").
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
#
# OR OpenAI (public API). NOTE: this sends extracted workplace content to an
# external provider — confirm it complies with your organization's data policy.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Wiki output ----
# Directory (relative to the llmwiki-pipeline root) where generated markdown
# docs are written and committed.
WIKI_DIR=app/wiki
