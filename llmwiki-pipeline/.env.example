# ================================================================
#  LLM Wiki Pipeline — environment configuration
#  Copy this file to `.env` and fill in the values.
#  `.env` is gitignored — never commit real credentials.
# ================================================================

# ---- Required: Entra ID (Azure AD) ----
# Directory (tenant) ID that owns the Mail / Teams MCP servers.
TENANT_ID=00000000-0000-0000-0000-000000000000

# Application (client) ID of your Entra app registration.
# The app must have delegated API permissions (admin-consented) to both the
# mcp_MailTools and mcp_TeamsServer resources (scopes McpServers.Mail.All /
# McpServers.Teams.All). This is the SAME kind of registration the Node
# samples under ../samples use.
CLIENT_ID=

# Client secret — required only when AUTH_MODE=client_credentials (app-only).
# Leave empty when using device-code (delegated) auth.
CLIENT_SECRET=

# ---- MCP servers ----
# Each source is a DIFFERENT OAuth resource (its own `.default` scope). A token
# issued for Mail is NOT valid for Teams; one token is acquired per source.
MAIL_MCP_SERVER_URL=https://agent365.svc.cloud.microsoft/agents/tenants/00000000-0000-0000-0000-000000000000/servers/mcp_MailTools
TEAMS_MCP_SERVER_URL=https://agent365.svc.cloud.microsoft/agents/tenants/00000000-0000-0000-0000-000000000000/servers/mcp_TeamsServer

# ---- Auth mode ----
# device_code      : delegated user login shown once in the notebook/terminal,
#                    then cached to TOKEN_CACHE_PATH (silent afterwards).
#                    RECOMMENDED — the MCP servers expose delegated scopes.
# client_credentials: app-only token via CLIENT_SECRET (only works if your
#                    tenant grants the app application permissions to the MCP
#                    resource; many tenants only allow delegated).
AUTH_MODE=device_code
TOKEN_CACHE_PATH=.token_cache.json

# ---- LLM (natural-language extraction + markdown generation) ----
# Pick ONE provider.
#
# Azure OpenAI (Foundry): auth is by Entra ID (DefaultAzureCredential:
# `az login` / managed identity) when AZURE_OPENAI_API_KEY is empty. The
# identity needs a data-plane role (e.g. "Cognitive Services OpenAI User").
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
#
# OR OpenAI:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Wiki output ----
# Directory (relative to the llmwiki-pipeline root) where generated markdown
# docs are written and committed.
WIKI_DIR=app/wiki
