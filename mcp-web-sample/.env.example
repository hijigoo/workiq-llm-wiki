# ---- Required: Entra ID (Azure AD) ----
# Directory (tenant) ID that owns the Mail / Teams MCP servers.
TENANT_ID=00000000-0000-0000-0000-000000000000

# Application (client) ID of YOUR Entra app registration.
# The app must:
#   - be a "Web" (or public) client with redirect URI = REDIRECT_URI below
#   - have delegated API permissions to BOTH the mcp_MailTools and
#     mcp_TeamsServer resources, with admin consent, if you want users to be
#     able to use both sources at the same time. If a resource isn't
#     consented, its checkbox will show a "connect" prompt instead of failing
#     the whole app.
CLIENT_ID=

# Optional: client secret if you registered a confidential (Web) app.
# Leave empty to use a public client with PKCE only.
CLIENT_SECRET=

# ---- MCP servers ----
# Each source is a DIFFERENT OAuth resource (different `.default` scope), even
# though they may live under the same tenant/app registration. A token issued
# for Mail is NOT valid for Teams and vice-versa — the app acquires one token
# per selected source.
MAIL_MCP_SERVER_URL=https://agent365.svc.cloud.microsoft/agents/tenants/00000000-0000-0000-0000-000000000000/servers/mcp_MailTools
TEAMS_MCP_SERVER_URL=https://agent365.svc.cloud.microsoft/agents/tenants/00000000-0000-0000-0000-000000000000/servers/mcp_TeamsServer

# ---- App ----
PORT=3002
REDIRECT_URI=http://localhost:3002/auth/callback
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Optional: natural-language chat (LLM) ----
# Pick ONE provider. If none is set, the chat box will tell you to use the
# Tools panel (which works without any LLM).
#
# Azure OpenAI (Foundry):
#   Auth is by Entra ID (Azure AD) when AZURE_OPENAI_API_KEY is empty.
#   The server identity (DefaultAzureCredential: az login / managed identity)
#   needs a data-plane role such as "Cognitive Services OpenAI User" or
#   "Foundry User" on the resource.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
#
# OR OpenAI:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
