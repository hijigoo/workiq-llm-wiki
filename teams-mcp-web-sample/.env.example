# ---- Required: Entra ID (Azure AD) ----
# Directory (tenant) ID that owns the Teams MCP server.
TENANT_ID=00000000-0000-0000-0000-000000000000

# Application (client) ID of YOUR Entra app registration.
# The app must:
#   - be a "Web" (or public) client with redirect URI = REDIRECT_URI below
#   - have a delegated API permission to the mcp_TeamsServer resource, with admin consent
CLIENT_ID=11111111-1111-1111-1111-111111111111

# Optional: client secret if you registered a confidential (Web) app.
# Leave empty to use a public client with PKCE only.
CLIENT_SECRET=your-client-secret-here

# ---- MCP server (Work IQ Teams) ----
# Full server URL. Replace the tenant GUID with your own TENANT_ID.
MCP_SERVER_URL=https://agent365.svc.cloud.microsoft/agents/tenants/00000000-0000-0000-0000-000000000000/servers/mcp_TeamsServer

# ---- App ----
PORT=3000
REDIRECT_URI=http://localhost:3000/auth/callback
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Optional: natural-language chat (LLM) ----
# Pick ONE provider. If none is set, the chat box will tell you to use the
# Tools panel (which works without any LLM).
#
# Azure OpenAI (Foundry):
#   Auth is by Entra ID (Azure AD) when AZURE_OPENAI_API_KEY is empty.
#   The server identity (DefaultAzureCredential: az login / managed identity)
#   needs a data-plane role such as "Cognitive Services OpenAI User" or
#   "Foundry User" on the resource.
AZURE_OPENAI_ENDPOINT=https://your-foundry-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2025-04-01-preview
#
# OR OpenAI:
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
